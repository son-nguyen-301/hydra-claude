{
  "$schema": "https://anthropic.com/claude-code/plugin.schema.json",
  "name": "hydra-claude",
  "version": "3.4.0",
  "description": "Hydra Claude: memory provider — auto-captures repo-specific patterns at session end and re-injects them on session start and post-compact.",
  "author": {
    "name": "Nguyen Hai Son"
  },
  "license": "MIT",
  "homepage": "https://github.com/son-nguyen-301/hydra-claude",
  "repository": "https://github.com/son-nguyen-301/hydra-claude",
  "keywords": [
    "memory",
    "patterns",
    "context",
    "learn",
    "claude-code"
  ],
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/inject-learned.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end-learn.sh\""
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-compact.sh\""
          }
        ]
      }
    ]
  }
}
