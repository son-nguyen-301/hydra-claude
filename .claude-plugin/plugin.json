{
  "name": "hydra-claude",
  "version": "1.0.0",
  "description": "Hydra Claude: token tracking, context compaction, and curated development agents and skills.",
  "author": {
    "name": "Nguyen Hai Son"
  },
  "license": "MIT",
  "agents": [
    "./agents/architect.md",
    "./agents/sprinter.md",
    "./agents/builder.md",
    "./agents/doc-writer.md"
  ],
  "skills": "./skills/",
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/statusline.sh\""
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/token-logger.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/context-compactor.sh\""
          }
        ]
      }
    ]
  }
}
